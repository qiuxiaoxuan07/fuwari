---
import { Icon } from "astro-icon/components";
import { profileConfig } from "../../config";
import { url } from "../../utils/url-utils";
import ImageWrapper from "../misc/ImageWrapper.astro";

const config = profileConfig;

const siteLinks = [
	{
		name: "监控站",
		url: "https://status.qiuxiaoxuan.com",
		icon: "fa6-solid:server",
	},
];
---
<div class="card-base p-3">
    <a aria-label="Go to About Page" href={url('/about/')}
       class="group block relative mx-auto mt-1 lg:mx-0 lg:mt-0 mb-3
       max-w-[12rem] lg:max-w-none overflow-hidden rounded-xl active:scale-95">
        <div class="absolute transition pointer-events-none group-hover:bg-black/30 group-active:bg-black/50
        w-full h-full z-50 flex items-center justify-center">
            <Icon name="fa6-regular:address-card"
                  class="transition opacity-0 scale-90 group-hover:scale-100 group-hover:opacity-100 text-white text-5xl">
            </Icon>
        </div>
        <ImageWrapper src={config.avatar || ""} alt="Profile Image of the Author" class="mx-auto lg:w-full h-full lg:mt-0 "></ImageWrapper>
    </a>
    <div class="px-2">
        <div class="font-bold text-xl text-center mb-1 dark:text-neutral-50 transition">{config.name}</div>
        <div class="h-1 w-5 bg-[var(--primary)] mx-auto rounded-full mb-2 transition"></div>
        <div class="text-center text-neutral-400 mb-2.5 transition">{config.bio}</div>
        <div class="flex flex-wrap gap-2 justify-center mb-1">
            {config.links.length > 1 && config.links.map(item => {
                const isCopy = item.url.startsWith('copy:');
                let title = undefined;
                if (isCopy) {
                    if (item.name === 'QQ') title = '点击复制QQ号';
                    else if (item.name === 'WeChat') title = '点击复制微信号';
                    else title = `点击复制${item.name}`;
                }
                return (
                    <a 
                        rel="me" 
                        aria-label={item.name} 
                        title={title}
                        href={isCopy ? 'javascript:void(0)' : item.url} 
                        target={isCopy ? undefined : '_blank'} 
                        data-copy-text={isCopy ? item.url.substring(5) : undefined}
                        class:list={[
                            "btn-menu rounded-lg h-10 w-10 active:scale-90",
                            { "copy-link-btn": isCopy }
                        ]}
                    >
                        <Icon name={item.icon} class="text-[1.5rem]"></Icon>
                    </a>
                )
            })}
            {config.links.length == 1 && (() => {
                const item = config.links[0];
                const isCopy = item.url.startsWith('copy:');
                let title = undefined;
                if (isCopy) {
                    if (item.name === 'QQ') title = '点击复制QQ号';
                    else if (item.name === 'WeChat') title = '点击复制微信号';
                    else title = `点击复制${item.name}`;
                }
                return (
                    <a 
                        rel="me" 
                        aria-label={item.name} 
                        title={title}
                        href={isCopy ? 'javascript:void(0)' : item.url} 
                        target={isCopy ? undefined : '_blank'} 
                        data-copy-text={isCopy ? item.url.substring(5) : undefined}
                        class:list={[
                            "btn-menu rounded-lg h-10 gap-2 px-3 font-bold active:scale-95",
                            { "copy-link-btn": isCopy }
                        ]}
                    >
                        <Icon name={item.icon} class="text-[1.5rem]"></Icon>
                        {item.name}
                    </a>
                )
            })()}
        </div>
    </div>

    <div class="w-full h-[1px] bg-neutral-100 dark:bg-neutral-800 my-4"></div>

    <div class="font-bold text-lg mb-3 ml-2 text-neutral-900 dark:text-neutral-100 transition-colors">
        网站列表
    </div>
    
    <div class="grid grid-cols-2 gap-3 px-2 pb-1">
        {siteLinks.map((item) => (
            <a 
                href={item.url} 
                target="_blank" 
                class="btn-menu h-10 gap-2 px-3 rounded-lg active:scale-95"
            >
                <div class="text-lg">
                    <Icon name={item.icon} />
                </div>
                <span class="font-medium text-sm">{item.name}</span>
            </a>
        ))}
    </div>
</div>

<script>
document.addEventListener("click", function (e: MouseEvent) {
    const target = e.target as Element | null;
    const btn = target?.closest(".copy-link-btn");
    if (btn) {
        e.preventDefault();
        const text = btn.getAttribute("data-copy-text");
        if (text) {
            navigator.clipboard.writeText(text).then(() => {
                const lang = document.documentElement.lang || "en";
                const prefix = (lang.startsWith("zh") || lang.startsWith("ZH")) ? "已复制" : "Copied";
                showToast(prefix + ": " + text);
            }).catch(err => {
                console.error("Failed to copy text: ", err);
            });
        }
    }
});

function showToast(message: string) {
    const toast = document.createElement("div");
    toast.className = "fixed top-5 left-1/2 -translate-x-1/2 z-50 bg-black/80 dark:bg-neutral-800/90 text-white dark:text-neutral-100 px-4 py-2.5 rounded-xl shadow-xl flex items-center gap-2 text-sm font-medium transition-all duration-300 opacity-0 translate-y-[-10px] pointer-events-none border border-neutral-700/50 dark:border-neutral-600/50";
    
    toast.innerHTML = `
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
        <span>${message}</span>
    `;
    
    document.body.appendChild(toast);
    
    // Trigger reflow
    toast.offsetHeight;
    
    // Animate in
    toast.classList.remove("opacity-0", "translate-y-[-10px]");
    toast.classList.add("opacity-100", "translate-y-0");
    
    // Hide and remove
    setTimeout(() => {
        toast.classList.remove("opacity-100", "translate-y-0");
        toast.classList.add("opacity-0", "translate-y-[-10px]");
        setTimeout(() => {
            toast.remove();
        }, 300);
    }, 2000);
}
</script>
